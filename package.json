{
  "name": "stem-studio",
  "productName": "Stem Studio",
  "version": "1.1.0",
  "description": "Desktop tool that separates a married film soundtrack into Dialogue, Music, and SFX stems — WAV output plus optional multitrack video for NLE import.",
  "main": "out/main/index.js",
  "author": "Sam Wasserman",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src tests --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && electron-builder --mac --config electron-builder.yml"
  },
  "dependencies": {
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
